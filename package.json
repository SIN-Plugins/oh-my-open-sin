{
  "name": "oh-my-open-sin",
  "version": "1.0.0",
  "description": "Native OpenCode SubAgent Framework - Replacing broken plugins with session-aware, non-blocking subagents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test dist/**/*.test.js",
    "verify:provenance": "node scripts/verify-sigstore.mjs --bundle dist/result.sigstore.json --payload dist/result.json --strict",
    "check:slo": "node scripts/slo-check.mjs --config slo-config.json --metrics-url http://localhost:9464/metrics --strict --json",
    "check:slo:notify": "node scripts/slo-check.mjs --config slo-config.json --webhook https://hooks.slack.com/services/YOUR/WEBHOOK"
  },
  "keywords": [
    "opencode",
    "subagent",
    "typescript",
    "automation",
    "git-orchestration"
  ],
  "author": "SIN-Plugins",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.215.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "yjs": "^13.6.30"
  }
}
